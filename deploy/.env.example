# relay deploy — copy to .env. TLS is terminated by the deployment environment.

# ── Identities ───────────────────────────────────────────────────────────────
# Connector settlement identity (BIP-39). Empty → pre-funded anvil acct-0 devnet
# fallback. If set, ALSO update routes[].settlementAddresses.evm in connector.yaml
# to the EVM address the connector prints at boot.
TOON_MNEMONIC=
# REQUIRED: relay Nostr identity (NOT money). Generate: openssl rand -hex 32
RELAY_NOSTR_SECRET_KEY=
# true skips Nostr signature verification on writes (smoke only).
RELAY_DEV_MODE=false

# ── Images ───────────────────────────────────────────────────────────────────
# The connector image baked into relay-connector (pin a concrete semver).
# connector.yaml's `selfAnnounce` block (kind:10032 emitter for #37/#22) requires
# the self-announce feature, which shipped in toon-protocol/connector v3.28.0
# (PR #265). Do not drop below 3.28.0 or the announce silently no-ops.
CONNECTOR_TAG=3.28.0
# The published relay-connector image (prod: pin a tag and `up` without --build).
RELAY_CONNECTOR_IMAGE=ghcr.io/toon-protocol/relay-connector:latest
# The published relay app image.
RELAY_IMAGE=ghcr.io/toon-protocol/relay:latest

# ── Ports ────────────────────────────────────────────────────────────────────
EDGE_PORT=3000
RELAY_WS_PORT=7100

# ── Misc ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Devnet RPC serves a self-signed cert — DEVNET ONLY (never for the public edge).
NODE_TLS_REJECT_UNAUTHORIZED=0
